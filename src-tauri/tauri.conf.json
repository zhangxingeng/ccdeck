{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Studio",
  "version": "0.5.0",
  "identifier": "com.zhangxingeng.ccstudio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code Studio",
        "width": 1100,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "endpoints": [
        "https://github.com/zhangxingeng/claude-code-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1QzM1NURFMTY5MDBDOUMKUldTY0RKQVczbFhEWlIvQ0F4d08yZXdsOFhlL1U0M2dvYXlSbWpvY1pPbmVWWkhVV0JlRm5FUVoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "shortDescription": "Browse and edit your Claude Code chat history, offline.",
    "longDescription": "An offline desktop app that auto-discovers your Claude Code sessions and renders them as clean, readable conversations — including thinking, tool calls, results, and subagents. Edit, prune, back up, and export history. Your data never leaves your machine.",
    "publisher": "zhangxingeng",
    "copyright": "Copyright (c) 2026 zhangxingeng. MIT licensed.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
