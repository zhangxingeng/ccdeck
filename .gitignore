.DS_Store
node_modules
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Claude Code project config: track settings.json + memory/MEMORY.md (they travel with the
# repo); ignore local overrides and ephemeral/session state.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/memory/*
!.claude/memory/MEMORY.md
# Hook fire-once dedup markers (per-session runtime state — hook_protocol.mdx)
.claude/hooks/.state/
# Colocated scratch: transient output lives beside its producer in a tmp/ dir
# (claude-workspace skill); one bare line covers every depth
tmp/

# Real chat history must never be committed (mock fixtures under tests/ are fine)
*.jsonl
!tests/mock_data/**/*.jsonl

# Nested/embedded repo: personal ai-first-docs scaffolding cloned alongside this project
/ai-first-docs/

# Playwright E2E output
/test-results/
/playwright-report/
/playwright/.cache/

# Compiled Python bytecode (hooks run via uv; caches are machine-local)
__pycache__/
